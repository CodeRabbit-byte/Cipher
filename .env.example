# ─────────────────────────────────────────────
# CIPHER — Environment Configuration
# Copy this file to .env and fill in the keys
# you want to use. Leave unused providers blank.
# ─────────────────────────────────────────────

# App
NEXTAUTH_SECRET=                  # Required. Run: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Database
DATABASE_URL=file:./data/cipher.db

# ─── AI PROVIDERS ────────────────────────────
# Set at least one. The active provider is
# controlled by AI_PROVIDER below.
# Leave unused keys blank — do not delete them.

AI_PROVIDER=anthropic             # Options: anthropic | openai | gemini | mistral | groq

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o)
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Groq
GROQ_API_KEY=

# ─── THREATASSESSOR INTEGRATION ───────────────────────────────
# Both must be set to enable the Threat Model tab in Ingest.
# If either is missing, the tab shows a configuration notice.
# These are server-side only — never use NEXT_PUBLIC_ prefix.

THREATASSESSOR_URL=http://localhost:8000
THREATASSESSOR_API_KEY=
